---
import type { Lang, UIStrings } from "../../i18n/ui";

interface Props {
  lang: Lang;
  t: (key: keyof UIStrings) => string;
}

const { lang, t } = Astro.props;
const cvUrl = "https://github.com/alliso/resume/blob/main/pdf/cv.pdf";
---

<section id="hero" class="hero-section">
  <div class="hero-content">
    <p class="hero-greeting">
      {lang === "en" ? "Hi, I'm" : "Hola, soy"}
    </p>
    <h1 class="hero-name">Alejandro Lliso Cosin</h1>
    <h2 class="hero-role">{t("hero.role")}</h2>
    <p class="hero-bio">{t("hero.bio")}</p>
    <div class="hero-actions">
      <a href={cvUrl} target="_blank" rel="noopener noreferrer" class="btn-primary">
        {t("hero.cv")}
      </a>
      <a href="#experience" class="btn-secondary">
        {t("hero.scrollDown")}
      </a>
    </div>
  </div>
</section>
